generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PanelAssignment {
  id        String   @id @default(uuid())
  title     String
  students  String[]
  set       String
  adviser   String
  chairman  String
  members   String[]
  secretary String
  createdAt DateTime @default(now())
}
